# WebSocket backend — defaults to ws://localhost:8080/ws
# Override if your backend runs on a different host/port.
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Spline 3D scene — leave blank to use the CSS liquid-orb fallback.
# 1. Build your scene at https://spline.design
# 2. Export → Viewer → copy the .splinecode URL
# 3. Paste it here (no quotes needed)
# Example: NEXT_PUBLIC_SPLINE_SCENE=https://prod.spline.design/XXXXXXXXXXXXXXXX/scene.splinecode
NEXT_PUBLIC_SPLINE_SCENE=

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic (Claude) API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs TTS — https://elevenlabs.io → Profile → API Keys
ELEVEN_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional — Voice Input ────────────────────────────────────────────────────

# Sarvam AI (server-side STT fallback) — https://dashboard.sarvam.ai
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs voice ID (default: JBFqnCBsd6RMkjVDRZzb — British male)
# Find voice IDs at https://api.elevenlabs.io/v1/voices
JARVIS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ── Optional — Smart Lights ───────────────────────────────────────────────────

# WLED LED strip (WiFi) — set to your device IP
WLED_IP=

# Philips Hue bridge
HUE_BRIDGE_IP=
HUE_USERNAME=

# ── Optional — Ticketing System ───────────────────────────────────────────────

SUPABASE_URL=https://your-project-id.supabase.co/rest/v1
SUPABASE_API_KEY=your-supabase-api-key

# ── Legacy / LiveKit voice agent (uv run friday_voice) ───────────────────────

LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
